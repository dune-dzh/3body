# Copy to .env and adjust, or run ./install.sh to auto-generate .env with LAN IP.
#
# Browsers will connect WebSockets to this origin when set. If PUBLIC_HOST is empty,
# the UI uses the same host/port as the page (typical for localhost).
#
PUBLIC_HOST=
PUBLIC_PORT=8000
PUBLIC_TLS=0

# Optional: full WebSocket origin (with or without trailing /ws), overrides host/port/tls.
# Example: PUBLIC_WS_URL=wss://example.com

PUBLIC_WS_URL=
